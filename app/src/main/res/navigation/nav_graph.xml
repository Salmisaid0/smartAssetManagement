<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_dashboard">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- BOTTOM NAVIGATION (5 ITEMS MAX - NO CRASH) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.etachi.smartassetmanagement.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_assets"
        android:name="com.etachi.smartassetmanagement.ui.assets.AssetsFragment"
        android:label="Assets"
        tools:layout="@layout/fragment_assets">
        <argument
            android:name="roomId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <!-- ✅ MATCHES YOUR CODE: actionAssetsFragmentToAssetDetailFragment -->
        <action
            android:id="@+id/action_assetsFragment_to_assetDetailFragment"
            app:destination="@id/assetDetailFragment" />
        <!-- ✅ MATCHES YOUR CODE: actionAssetsFragmentToAddAssetFragment -->
        <action
            android:id="@+id/action_assetsFragment_to_addAssetFragment"
            app:destination="@id/addAssetFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_scanner"
        android:name="com.etachi.smartassetmanagement.ui.scanner.ScannerFragment"
        android:label="Scanner"
        tools:layout="@layout/fragment_scanner" />

    <!-- ✅ Inventory Home (Landing Page) - Bottom Nav Item -->
    <fragment
        android:id="@+id/inventoryHomeFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.home.InventoryHomeFragment"
        android:label="Inventory"
        tools:layout="@layout/fragment_inventory_home">
        <action
            android:id="@+id/action_inventoryHomeFragment_to_inventoryRoomScanFragment"
            app:destination="@id/inventoryRoomScanFragment" />
        <action
            android:id="@+id/action_inventoryHomeFragment_to_inventoryHistoryFragment"
            app:destination="@id/inventoryHistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.etachi.smartassetmanagement.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ASSET FLOW -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <fragment
        android:id="@+id/assetDetailFragment"
        android:name="com.etachi.smartassetmanagement.ui.detail.AssetDetailFragment"
        android:label="Asset Detail"
        tools:layout="@layout/fragment_asset_detail">
        <argument
            android:name="assetId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/addAssetFragment"
        android:name="com.etachi.smartassetmanagement.ui.detail.AddAssetFragment"
        android:label="Add Asset"
        tools:layout="@layout/fragment_add_asset">
        <argument
            android:name="assetObj"
            app:argType="com.etachi.smartassetmanagement.data.model.Asset"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- INVENTORY FLOW (COMPLETE) -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- 1. Room Scan (First step in inventory) -->
    <fragment
        android:id="@+id/inventoryRoomScanFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.InventoryRoomScanFragment"
        android:label="Scan Room"
        tools:layout="@layout/fragment_inventory_room_scan">
        <action
            android:id="@+id/action_inventoryRoomScanFragment_to_inventoryAssetScanFragment"
            app:destination="@id/inventoryAssetScanFragment"
            app:popUpTo="@id/inventoryRoomScanFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- 2. Asset Scan (Second step - scan assets in room) -->
    <fragment
        android:id="@+id/inventoryAssetScanFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.InventoryAssetScanFragment"
        android:label="Scan Assets"
        tools:layout="@layout/fragment_inventory_asset_scan">
        <argument
            android:name="sessionId"
            app:argType="string" />
    </fragment>

    <!-- 3. Missing Assets (Third step - results after completion) -->
    <fragment
        android:id="@+id/inventoryMissingAssetsFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.InventoryMissingAssetsFragment"
        android:label="Missing Assets"
        tools:layout="@layout/fragment_inventory_missing_assets">
        <argument
            android:name="sessionId"
            app:argType="string" />
    </fragment>

    <!-- 4. History (List of all inventory sessions) -->
    <fragment
        android:id="@+id/inventoryHistoryFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.history.InventoryHistoryFragment"
        android:label="Inventory History"
        tools:layout="@layout/fragment_inventory_history">
        <action
            android:id="@+id/action_inventoryHistoryFragment_to_inventorySessionDetailsFragment"
            app:destination="@id/inventorySessionDetailsFragment" />
    </fragment>

    <!-- 5. Session Details (View single session details) -->
    <fragment
        android:id="@+id/inventorySessionDetailsFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.details.InventorySessionDetailsFragment"
        android:label="Session Details"
        tools:layout="@layout/fragment_inventory_session_details">
        <argument
            android:name="session"
            app:argType="com.etachi.smartassetmanagement.domain.model.InventorySession" />
    </fragment>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- SPRINT 3: SCHEDULING -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <fragment
        android:id="@+id/scheduledInventoryListFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.scheduled.ScheduledInventoryListFragment"
        android:label="Scheduled Inventories"
        tools:layout="@layout/fragment_scheduled_inventory_list">
        <action
            android:id="@+id/action_scheduledInventoryListFragment_to_createScheduledInventoryFragment"
            app:destination="@id/createScheduledInventoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/createScheduledInventoryFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.scheduled.CreateScheduledInventoryFragment"
        android:label="Schedule Inventory"
        tools:layout="@layout/fragment_create_scheduled_inventory" />

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- SPRINT 3: REPORTS -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <fragment
        android:id="@+id/inventoryReportFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.report.InventoryReportFragment"
        android:label="Inventory Report"
        tools:layout="@layout/fragment_inventory_report">
        <argument
            android:name="sessionId"
            app:argType="string" />
    </fragment>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- SPRINT 3: RELOCATION -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <fragment
        android:id="@+id/relocationRequestListFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.relocation.RelocationRequestListFragment"
        android:label="Relocation Requests"
        tools:layout="@layout/fragment_relocation_request_list">
        <action
            android:id="@+id/action_relocationRequestListFragment_to_createRelocationRequestFragment"
            app:destination="@id/createRelocationRequestFragment" />
    </fragment>

    <fragment
        android:id="@+id/createRelocationRequestFragment"
        android:name="com.etachi.smartassetmanagement.ui.inventory.relocation.CreateRelocationRequestFragment"
        android:label="Request Relocation"
        tools:layout="@layout/fragment_create_relocation_request">
        <argument
            android:name="assetId"
            app:argType="string" />
    </fragment>

</navigation>
