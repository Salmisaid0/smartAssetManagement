<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_margin="12dp"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingVertical="10dp">


    <FrameLayout
        android:id="@+id/histIconBox"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_icon_surface">

        <ImageView
            android:id="@+id/histIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/histTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/dash_text_secondary"
            tools:text="Laptop #LPT-0042" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/histSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/dash_text_hint"
            tools:text="Scanned by Ahmed K." />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/histBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:letterSpacing="0.04"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            tools:text="Active" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/histTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.02"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/dash_text_hint"
            tools:text="2m ago" />
    </LinearLayout>

</LinearLayout>