<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Asset Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <!-- ✅ Status Indicator (Left Color Bar) -->
        <View
            android:id="@+id/viewStatusIndicator"
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="@color/dash_teal" />

        <!-- ✅ Asset Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- ✅ Asset Name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textAssetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Dell XPS 15" />

            <!-- ✅ Asset Details -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textAssetDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_muted"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="IT Dept • SN-12345" />
        </LinearLayout>

        <!-- ✅ Status Text (Minimal Badge) -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/dash_teal"
            android:background="@drawable/bg_status_active"
            android:maxLines="1"
            tools:text="Active" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />
</LinearLayout>
