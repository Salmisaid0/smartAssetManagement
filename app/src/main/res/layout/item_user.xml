<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/dash_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/dash_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- User Initial Circle -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textUserInitial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_teal_large"
            android:gravity="center"
            android:textColor="@color/dash_teal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- User Name (Using the new Sprint 1 method) -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/dash_text_primary" />

            <!-- User Email -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/dash_text_muted" />
        </LinearLayout>

        <!-- Role Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipUserRole"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:text="Role" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>