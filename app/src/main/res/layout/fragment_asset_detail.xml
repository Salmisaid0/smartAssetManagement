<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:fitsSystemWindows="true">

    <!-- 1. TOOLBAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dash_surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/dash_text_primary"
            app:title="Asset Details"
            app:titleTextColor="@color/dash_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <!-- 2. HEADER CARD (Teal wrapper) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/dash_teal"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.02"
                        android:textAppearance="?attr/textAppearanceHeadlineLarge"
                        android:textColor="@color/dash_bg"
                        tools:text="Asset Name" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_bg"
                        tools:text="ID: IT-001" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDetailStatus"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="false"
                        android:textAllCaps="true"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        app:chipBackgroundColor="#20FFFFFF"
                        app:chipCornerRadius="8dp"
                        app:chipMinHeight="28dp"
                        android:textColor="@color/dash_bg"
                        tools:text="ACTIVE" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. IOT DATA (NOW EXACTLY DASHBOARD STAT CARDS) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal">

                <!-- Temp Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/dash_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dash_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="14dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <View
                            android:layout_width="32dp"
                            android:layout_height="2dp"
                            android:background="@color/dash_amber"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:importantForAccessibility="no"
                            android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textColor="@color/dash_text_primary"
                            tools:text="-- °C" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:importantForAccessibility="no"
                            android:letterSpacing="0.07"
                            android:text="Temp"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/dash_border"
                            android:importantForAccessibility="no">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/dash_amber_surface" />
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Battery Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/dash_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dash_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="14dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <View
                            android:layout_width="32dp"
                            android:layout_height="2dp"
                            android:background="@color/dash_teal"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:importantForAccessibility="no"
                            android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textColor="@color/dash_text_primary"
                            tools:text="-- %" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:importantForAccessibility="no"
                            android:letterSpacing="0.07"
                            android:text="Battery"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/dash_border"
                            android:importantForAccessibility="no">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/dash_teal_surface" />
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Connection Status Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/dash_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dash_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="14dp"
                        android:paddingBottom="12dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <View
                            android:layout_width="32dp"
                            android:layout_height="2dp"
                            android:background="@color/dash_blue"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:importantForAccessibility="no"
                            android:textAppearance="?attr/textAppearanceHeadlineMedium"
                            android:textColor="@color/dash_text_primary"
                            tools:text="Offline" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:importantForAccessibility="no"
                            android:letterSpacing="0.07"
                            android:text="Status"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/dash_border"
                            android:importantForAccessibility="no">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/dash_blue_surface" />
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 4. INFO GRID SECTION (Dashboard style headers) -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.08"
                android:text="ASSET INFORMATION"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/dash_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="CATEGORY"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="24dp"
                            android:background="@color/dash_border"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:letterSpacing="0.06"
                            android:text="OWNER"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailOwner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />
                    </LinearLayout>

                    <!-- Vertical Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="16dp"
                        android:background="@color/dash_border"
                        android:importantForAccessibility="no" />

                    <!-- Right Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="SERIAL NUMBER"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailSerial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="24dp"
                            android:background="@color/dash_border"
                            android:importantForAccessibility="no" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:letterSpacing="0.06"
                            android:text="LOCATION"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 5. PREMIUM BOTTOM ACTION BAR -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/dash_surface"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/dash_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Delete"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/dash_amber"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/dash_amber"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEdit"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/dash_teal"
                    android:text="Edit Asset"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/dash_bg"
                    app:cornerRadius="12dp"
                    app:elevation="0dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>