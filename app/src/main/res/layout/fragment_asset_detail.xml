<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- APP BAR -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dash_bg"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Asset Details"
            app:titleTextColor="@color/dash_text_primary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/dash_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONTENT -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- Asset Name Header -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold"
                tools:text="Dell XPS 15" />

            <!-- Asset ID -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textDetailId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint"
                android:fontFamily="monospace"
                tools:text="ID: AST-001234" />

            <!-- Status Indicator -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/chipDetailStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_teal"
                android:background="@drawable/bg_status_active"
                android:textStyle="bold"
                tools:text="Active" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/dash_border" />

            <!-- Section: Information -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Information"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/dash_text_hint"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />

            <!-- Info Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <!-- Type Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Type"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailCategory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_primary"
                        tools:text="Laptop" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <!-- Serial Number Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Serial"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailSerial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_primary"
                        android:fontFamily="monospace"
                        tools:text="SN-12345678" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <!-- Owner Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Owner"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailOwner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_primary"
                        tools:text="John Doe" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <!-- Location Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_primary"
                        tools:text="IT / Development / Room 301" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <!-- Added Date Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Added"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_primary"
                        tools:text="18 Apr 2026" />
                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="@color/dash_border" />

            <!-- Section: IoT Status (If Available) -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IoT Status"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/dash_text_hint"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />

            <!-- IoT Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <!-- Temperature -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/dash_text_primary"
                        tools:text="24°C" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Temp"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/dash_text_muted" />
                </LinearLayout>

                <!-- Battery -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/dash_text_primary"
                        tools:text="85%" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Battery"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/dash_text_muted" />
                </LinearLayout>

                <!-- Connection -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/dash_teal"
                        tools:text="Online" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Status"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/dash_text_muted" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ACTION BUTTONS -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/dash_surface"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Delete"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/error"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/error"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Edit"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:backgroundTint="@color/dash_teal"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
