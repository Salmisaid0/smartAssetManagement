<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:fitsSystemWindows="true">

    <!-- 1. MODERN TOOLBAR (Themed to dash system) -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dash_surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/dash_text_primary"
            app:title="Asset Details"
            app:titleTextColor="@color/dash_text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 2. DYNAMIC HEADER CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="@color/dash_teal"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.02"
                        android:textAppearance="?attr/textAppearanceHeadlineLarge"
                        android:textColor="@color/dash_bg"
                        tools:text="Asset Name" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textDetailId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_bg"
                        tools:text="ID: IT-001" />

                    <!-- SAFE STATUS PILL -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDetailStatus"
                        style="@style/Widget.Material3.Chip.Assist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:clickable="false"
                        android:textAllCaps="true"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        app:chipBackgroundColor="#20FFFFFF"
                        app:chipCornerRadius="8dp"
                        app:chipMinHeight="28dp"
                        android:textColor="@color/dash_bg"
                        tools:text="ACTIVE" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. IOT LIVE DATA CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/dash_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Live Status"
                            android:src="@drawable/bg_status_active"
                            app:tint="@color/dash_teal" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Live IoT Status"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/dash_text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textTemp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                                android:textColor="@color/dash_amber"
                                tools:text="-- °C" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="TEMP"
                                android:textAllCaps="true"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="@color/dash_text_hint" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textBattery"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                                android:textColor="@color/dash_teal"
                                tools:text="-- %" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="BATTERY"
                                android:textAllCaps="true"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="@color/dash_text_hint" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/textStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceTitleSmall"
                                android:textColor="@color/dash_text_muted"
                                tools:text="Offline" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="STATUS"
                                android:textAllCaps="true"
                                android:textAppearance="?attr/textAppearanceLabelSmall"
                                android:textColor="@color/dash_text_hint" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. INFO GRID SECTION -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.08"
                android:text="ASSET INFORMATION"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="@color/dash_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Left Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="CATEGORY"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:letterSpacing="0.06"
                            android:text="OWNER"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailOwner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />
                    </LinearLayout>

                    <!-- Vertical Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="16dp"
                        android:background="@color/dash_border"
                        android:importantForAccessibility="no" />

                    <!-- Right Column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="SERIAL NUMBER"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailSerial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:letterSpacing="0.06"
                            android:text="LOCATION"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textDetailLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="N/A" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 5. PREMIUM BOTTOM ACTION BAR (Flat dash design) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/dash_surface"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/dash_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top border line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Delete: Amber outline to match destructive pattern -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Delete"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/dash_amber"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/dash_amber"
                    app:strokeWidth="1dp" />

                <!-- Edit: Teal solid to match primary actions -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEdit"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/dash_teal"
                    android:text="Edit Asset"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/dash_bg"
                    app:cornerRadius="12dp"
                    app:elevation="0dp" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>