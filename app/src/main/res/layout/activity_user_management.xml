<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. TOP BANNER (Teal surface) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/dash_teal_surface" />

        <!-- 2. OVERLAPPING AVATAR -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="-40dp"
            app:cardBackgroundColor="@color/dash_surface"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textUserInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="@color/dash_teal"
                tools:text="A" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 3. USER IDENTITY BLOCK (Dashboard typography) -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/textProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:letterSpacing="-0.02"
            android:text="My Profile"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/dash_text_primary" />

        <!-- Role Pill (Matches Dashboard header pill exactly) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_role_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_status_dot"
                android:importantForAccessibility="no" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:importantForAccessibility="no"
                android:letterSpacing="0.06"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_muted"
                tools:text="Administrator" />
        </LinearLayout>

        <!-- 4. INFORMATION CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/dash_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Email Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Email Icon"
                        android:src="@drawable/ic_mail"
                        app:tint="@color/dash_text_muted" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="Email Address"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textColor="@color/dash_text_primary"
                            tools:text="user@company.com" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Custom Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/dash_border"
                    android:importantForAccessibility="no" />

                <!-- ID Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="ID Icon"
                        android:src="@drawable/finger_print_svgrepo_com"
                        app:tint="@color/dash_text_muted" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="Account ID"
                            android:textAllCaps="true"
                            android:textAppearance="?attr/textAppearanceLabelSmall"
                            android:textColor="@color/dash_text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/textUserId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/dash_text_muted"
                            tools:text="UID-9x8f7d6s" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. ACTION MENU CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/dash_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ═══ NEW: MANAGE ROLES ROW (ADMIN ONLY) ═══ -->
                <LinearLayout
                    android:id="@+id/btnManageRoles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Manage Roles"
                        android:src="@drawable/group_svgrepo_com"
                        app:tint="@color/dash_teal" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Manage Roles"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/dash_text_primary" />
                </LinearLayout>

                <!-- Divider for Manage Roles (Hidden by default) -->
                <View
                    android:id="@+id/dividerRoles"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="56dp"
                    android:background="@color/dash_border"
                    android:importantForAccessibility="no"
                    android:visibility="gone" />

                <!-- Settings Row -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Settings"
                        android:src="@drawable/setting_svgrepo_com"
                        app:tint="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="App Settings"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/dash_text_primary" />
                </LinearLayout>

                <!-- Custom Indented Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="56dp"
                    android:background="@color/dash_border"
                    android:importantForAccessibility="no" />

                <!-- Logout Row -->
                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Logout"
                        android:src="@drawable/logout_circle_svgrepo_com__1_"
                        app:tint="@color/dash_amber" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Logout"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/dash_amber" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>