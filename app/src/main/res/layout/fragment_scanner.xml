<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <!-- 1. HEADER -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/dash_text_hint"
            android:text="Scanner" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="-0.02"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/dash_text_primary"
            android:text="Operations" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/dash_text_muted"
            android:text="Scan assets to check status, assign, or move." />

        <!-- 2. MODE SELECTOR -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupModes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIdentify"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Identify"
                    android:checked="true"
                    app:chipBackgroundColor="@color/dash_chip_bg_state"
                    app:chipStrokeColor="@color/dash_chip_stroke_state"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/dash_chip_text_state" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCheckIn"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Check-In"
                    app:chipBackgroundColor="@color/dash_chip_bg_state"
                    app:chipStrokeColor="@color/dash_chip_stroke_state"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/dash_chip_text_state" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMaintenance"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Maintenance"
                    app:chipBackgroundColor="@color/dash_chip_bg_state"
                    app:chipStrokeColor="@color/dash_chip_stroke_state"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/dash_chip_text_state" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAudit"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Audit"
                    app:chipBackgroundColor="@color/dash_chip_bg_state"
                    app:chipStrokeColor="@color/dash_chip_stroke_state"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/dash_chip_text_state" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- 3. SCAN ACTION ZONE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/dash_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingVertical="40dp">

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_icon_teal_large">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/qr_code_svgrepo_com"
                        app:tint="@color/dash_teal" />
                </FrameLayout>

                <View
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="20dp"
                    android:background="@color/dash_teal"
                    android:importantForAccessibility="no" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:letterSpacing="-0.01"
                    android:text="Ready to Scan"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="@color/dash_text_primary" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Point your camera at an asset QR code"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/dash_text_muted" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnStartScan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/dash_teal"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/dash_bg" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:letterSpacing="0.02"
                            android:text="Start Scanning"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/dash_bg" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. RECENT SCANS HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.08"
                android:text="Recent Scans"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textScansCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_teal"
                tools:text="0 today" />
        </LinearLayout>

        <!-- 5. HISTORY CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/dash_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:importantForAccessibility="no" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvScanHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingVertical="8dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_scan_history" />

                    <LinearLayout
                        android:id="@+id/emptyStateView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="48dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:alpha="0.25"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_history"
                            app:tint="@color/dash_text_muted" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="No scans yet"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/dash_text_muted" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:alpha="0.6"
                            android:gravity="center"
                            android:text="Start scanning to see history"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/dash_text_hint" />
                    </LinearLayout>

                </FrameLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>