<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootWizardSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dash_surface"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- PROGRESS BAR -->
    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal">

        <View
            android:id="@+id/ind1"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_inactive" />

        <View
            android:id="@+id/ind2"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_step_inactive" />

        <View
            android:id="@+id/ind3"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_step_inactive" />
    </LinearLayout>

    <!-- DYNAMIC CONTENT CONTAINER -->
    <FrameLayout
        android:id="@+id/wizardContentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="250dp"
        android:background="@color/dash_surface"
        android:layout_marginHorizontal="16dp" />

    <!-- ERROR TEXT -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/textError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@color/error_container"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textColor="@color/on_error_container"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone" />

    <!-- ACTION BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            style="@style/Widget.Material3.Button.UnelevatedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:backgroundTint="@color/dash_teal"
            android:textColor="@color/dash_bg"
            android:text="Next" />
    </LinearLayout>

</LinearLayout>
