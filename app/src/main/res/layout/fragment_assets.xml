<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ─── HEADER (Matches Dashboard Style) ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/dash_surface"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="0dp">

            <!-- Section Title -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="INVENTORY"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:letterSpacing="-0.02"
                android:text="Manage your assets"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/dash_text_primary" />

            <!-- Search + Scan Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <!-- Search Box styled as Dashboard Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/dash_surface_elevated"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dash_border"
                    app:strokeWidth="1dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/searchInputLayout"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Search by name or ID…"
                        app:boxBackgroundColor="@android:color/transparent"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:boxCollapsedPaddingTop="0dp"
                        app:startIconTint="@color/dash_text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTextSearch"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="textFilter"
                            android:paddingVertical="0dp"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/dash_text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Scan Button styled as Dashboard Action -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnScan"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/dash_surface_elevated"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dash_border"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Scan asset barcode"
                        android:src="@drawable/qr_code_svgrepo_com"
                        app:tint="@color/dash_text_muted" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_gravity="center"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    android:layout_gravity="center"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:checked="true"
                        android:textColor="@color/dash_text_primary"
                        app:chipBackgroundColor="@color/dash_surface_elevated"
                        app:chipStrokeColor="@color/dash_border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActive"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        app:chipIconVisible="true"
                        app:chipIcon="@drawable/bg_circle_surface"
                        app:chipIconTint="@color/dash_teal"
                        android:textColor="@color/dash_text_primary"
                        app:chipBackgroundColor="@color/dash_surface_elevated"
                        app:chipStrokeColor="@color/dash_border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipMaintenance"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maintenance"
                        app:chipIconVisible="true"
                        app:chipIcon="@drawable/bg_circle_surface"
                        app:chipIconTint="@color/dash_amber"
                        android:textColor="@color/dash_text_primary"
                        app:chipBackgroundColor="@color/dash_surface_elevated"
                        app:chipStrokeColor="@color/dash_border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipRetired"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retired"
                        app:chipIconVisible="true"
                        app:chipIcon="@drawable/bg_circle_surface"
                        app:chipIconTint="@color/dash_text_muted"
                        android:textColor="@color/dash_text_primary"
                        app:chipBackgroundColor="@color/dash_surface_elevated"
                        app:chipStrokeColor="@color/dash_border"
                        app:chipStrokeWidth="1dp" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- Subtle 1dp Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />

        <!-- Result Count (Matches Dashboard Header Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textResultCount"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:letterSpacing="0.07"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/dash_text_hint"
                tools:text="247 assets" />

        </LinearLayout>

        <!-- ─── SWIPE REFRESH + LIST ─── -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewAssets"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="100dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_asset" />

                <!-- Empty State (Matches Dashboard Empty State Style) -->
                <LinearLayout
                    android:id="@+id/emptyStateView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="40dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:alpha="0.25"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_inventory"
                        app:tint="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="No Assets Found"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/dash_text_muted" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/textEmptyMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.6"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:text="Tap the + button to add your first asset."
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/dash_text_hint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEmptyAdd"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Add First Asset"
                        app:icon="@drawable/add_square_svgrepo_com" />
                </LinearLayout>

            </FrameLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- FAB styled as Dashboard Accent -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Add new asset"
        app:backgroundTint="@color/dash_teal"
        app:tint="@android:color/white"
        app:srcCompat="@drawable/add_square_svgrepo_com"
        app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>