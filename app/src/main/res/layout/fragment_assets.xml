<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    android:fitsSystemWindows="true">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- APP BAR -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dash_bg"
        app:elevation="0dp">

        <!-- Toolbar with Status Bar Padding -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Assets"
            app:titleTextColor="@color/dash_text_primary"
            app:titleTextAppearance="?attr/textAppearanceHeadlineSmall" />

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Search Input -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_status_active"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">



                <EditText
                    android:id="@+id/editTextSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:hint="Search..."
                    android:textColor="@color/dash_text_primary"
                    android:textColorHint="@color/dash_text_hint"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionSearch" />
            </LinearLayout>

            <!-- Scan Button -->
            <ImageView
                android:id="@+id/btnScan"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:src="@drawable/qr_code_svgrepo_com"
                app:tint="@color/dash_teal"
                android:contentDescription="Scan QR"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="All"
                    android:checked="true"
                    android:textSize="13sp"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActive"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Active"
                    android:textSize="13sp"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMaintenance"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Maintenance"
                    android:textSize="13sp"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRetired"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Retired"
                    android:textSize="13sp"
                    app:chipCornerRadius="16dp" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONTENT -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- RecyclerView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAssets"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="80dp"
                android:overScrollMode="never"
                tools:listitem="@layout/item_asset" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyStateView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_inventory"
                app:tint="@color/dash_text_hint"
                android:alpha="0.4"
                android:contentDescription="No assets" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No Assets"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Tap + to add your first asset"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/dash_text_muted" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- FLOATING ACTION BUTTON -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add new asset"
        android:src="@drawable/add_square_svgrepo_com"
        app:backgroundTint="@color/dash_teal"
        app:fabSize="normal"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
