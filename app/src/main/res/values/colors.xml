    <!-- ======================================================== -->
    <color name="md_theme_dark_primary">#A9C7FF</color>
    <color name="md_theme_dark_onPrimary">#003062</color>
    <color name="md_theme_dark_secondary">#C2C9D6</color>
    <color name="md_theme_dark_onSecondary">#253141</color>
    <color name="md_theme_dark_error">#FFB4AB</color>
    <color name="md_theme_dark_onError">#690005</color>
    <color name="md_theme_dark_background">#1A1C1E</color>
    <color name="md_theme_dark_surface">#1A1C1E</color>
    <color name="md_theme_dark_onBackground">#E2E3E8</color>
    <color name="md_theme_dark_onSurface">#E2E3E8</color>
    <color name="md_theme_dark_onSurfaceVariant">#C4C6D0</color>
