<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Primary Brand Color (A deep, trustworthy corporate blue) -->
    <color name="md_theme_light_primary">#1A56DB</color>
    <color name="md_theme_light_onPrimary">#FFFFFF</color>

    <!-- Secondary Brand Color (For accents/icons) -->
    <color name="md_theme_light_secondary">#5A6270</color>
    <color name="md_theme_light_onSecondary">#FFFFFF</color>

    <!-- Tertiary Color (For special highlights) -->
    <color name="md_theme_light_tertiary">#006B5E</color>
    <color name="md_theme_light_onTertiary">#FFFFFF</color>

    <!-- Error & Success (Crucial for UI feedback) -->
    <color name="md_theme_light_error">#BA1A1A</color>
    <color name="md_theme_light_onError">#FFFFFF</color>
    <color name="md_theme_light_success">#006D3B</color>

    <!-- Surfaces (Backgrounds and Cards - Notice they are slightly off-white, not pure #FFFFFF) -->
    <color name="md_theme_light_background">#F8F9FA</color>
    <color name="md_theme_light_surface">#F8F9FA</color>

    <!-- Text Colors (Never use pure black #000000 for text, it's too harsh) -->
    <color name="md_theme_light_onBackground">#1A1C1E</color>
    <color name="md_theme_light_onSurface">#1A1C1E</color>
    <color name="md_theme_light_onSurfaceVariant">#44474E</color>

    <!-- ======================================================== -->
